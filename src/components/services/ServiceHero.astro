---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  icon?: any;
  badge: string;
}

const { title, subtitle, description, icon: Icon, badge } = Astro.props;
---

<section
  class="bg-[linear-gradient(145deg,#f8fafc_0%,#fffafa_48%,#f8fafc_100%)] py-14 md:py-24"
>
  <div class="container mx-auto px-5">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex flex-col items-center mb-7">
        {
          Icon && (
            <div class="w-14 h-14 md:w-16 md:h-16 bg-[#FF6F61] rounded-2xl flex items-center justify-center text-white shadow-lg shadow-[#FF6F61]/20 mb-5 transition-transform duration-300 hover:scale-[1.03]">
              <Icon className="w-8 h-8" />
            </div>
          )
        }
        <span
          class="inline-block px-4 py-2 rounded-full bg-[#FFF1EF] text-[#B8463C] text-xs md:text-sm font-bold uppercase tracking-widest ring-1 ring-[#FFD7D1]"
        >
          {badge}
        </span>
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 mb-5 leading-tight tracking-tight">
        {title}
      </h1>
      <h2
        class="text-xl md:text-2xl font-bold text-[#D84F44] mb-6 leading-snug"
      >
        {subtitle}
      </h2>
      <p class="text-base md:text-lg text-gray-600 leading-relaxed max-w-3xl mx-auto">
        {description}
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-2 text-xs font-bold text-slate-500">
        <span class="rounded-full border border-slate-200 bg-white px-4 py-2">Free shortlist</span>
        <span class="rounded-full border border-slate-200 bg-white px-4 py-2">Private first</span>
        <span class="rounded-full border border-slate-200 bg-white px-4 py-2">No obligation</span>
      </div>
    </div>
  </div>
</section>
