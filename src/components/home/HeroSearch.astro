---
// HeroSearch - Alpine.js version (replaces React)
// Lightweight, fast, no hydration errors
interface Props {
    initialDestination?: string;
    initialService?: string;
    className?: string;
}

const {
    initialDestination = "",
    initialService = "",
    className = "",
} = Astro.props;

const cantons = [
    { name: "Zurich", code: "ZH", slug: "zurich" },
    { name: "Geneva", code: "GE", slug: "geneva" },
    { name: "Basel-Stadt", code: "BS", slug: "basel" },
    { name: "Zug", code: "ZG", slug: "zug" },
    { name: "Vaud", code: "VD", slug: "lausanne" },
    { name: "Bern", code: "BE", slug: "bern" },
    { name: "Lucerne", code: "LU", slug: "lucerne" },
    { name: "St. Gallen", code: "SG", slug: "st-gallen" },
];

const services = [
    { name: "Housing Search", slug: "housing-search" },
    { name: "Visa & Immigration", slug: "immigration-services" },
    { name: "Moving Logistics", slug: "moving-logistics" },
    { name: "School Search", slug: "education" },
    { name: "Strategic Advisory", slug: "settling-in" },
];
---

<div
    x-data="{
        activeTab: 'private',
        when: '',
        where: '',
        service: '',
        companyName: '',
        yearlyVolume: '',
        primaryDestination: '',

        handlePrivateSubmit() {
            if (this.$store.assessmentModal) {
                this.$store.assessmentModal.open({
                    mode: 'private',
                    initialCanton: this.where,
                    initialService: this.service,
                    when: this.when
                });
            }
        },

        handleCorporateSubmit() {
            if (this.$store.assessmentModal) {
                this.$store.assessmentModal.open({
                    mode: 'corporate',
                    initialCanton: this.primaryDestination,
                    company: this.companyName,
                    volume: this.yearlyVolume
                });
            }
        }
    }"
    x-init={`
        where = '${initialDestination}';
        service = '${initialService}';
        primaryDestination = '${initialDestination}';
    `}
    class={`bg-white rounded-3xl shadow-[0_40px_80px_-20px_rgba(0,0,0,0.2)] ring-1 ring-slate-900/5 overflow-hidden w-full transition-all duration-300 ${className}`}
>
    <!-- Tabs -->
    <div class="flex border-b border-slate-100">
        <button
            @click="activeTab = 'private'"
            :class="activeTab === 'private' ? 'bg-white text-slate-900 border-b-2 border-[#FF6F61]' : 'bg-slate-50/50 text-slate-400 border-b-2 border-transparent hover:text-slate-600 hover:bg-slate-50'"
            class="flex-1 py-5 text-center font-bold text-xs uppercase tracking-widest transition-all"
        >
            Private Move
        </button>
        <button
            @click="activeTab = 'corporate'"
            :class="activeTab === 'corporate' ? 'bg-white text-slate-900 border-b-2 border-[#FF6F61]' : 'bg-slate-50/50 text-slate-400 border-b-2 border-transparent hover:text-slate-600 hover:bg-slate-50'"
            class="flex-1 py-5 text-center font-bold text-xs uppercase tracking-widest transition-all"
        >
            Corporate / HR
        </button>
    </div>

    <!-- Private Move Form -->
    <form
        x-show="activeTab === 'private'"
        x-cloak
        @submit.prevent="handlePrivateSubmit()"
        class="p-8 space-y-6"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
    >
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- When -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">
                    <svg
                        class="w-4 h-4 inline-block mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                        ></path>
                    </svg>
                    When are you moving?
                </label>
                <select
                    x-model="when"
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#FF6F61] focus:border-transparent transition-all"
                >
                    <option value="">Select timeframe</option>
                    <option value="immediately"
                        >Immediately (within 1 month)</option
                    >
                    <option value="1-3-months">1-3 months</option>
                    <option value="3-6-months">3-6 months</option>
                    <option value="6-12-months">6-12 months</option>
                    <option value="planning">Just planning</option>
                </select>
            </div>

            <!-- Where -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">
                    <svg
                        class="w-4 h-4 inline-block mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                        ></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    Where in Switzerland?
                </label>
                <select
                    x-model="where"
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#FF6F61] focus:border-transparent transition-all"
                >
                    <option value="">Select destination</option>
                    {
                        cantons.map((canton) => (
                            <option value={canton.slug}>{canton.name}</option>
                        ))
                    }
                </select>
            </div>

            <!-- Service -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">
                    <svg
                        class="w-4 h-4 inline-block mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                        ></path>
                    </svg>
                    What service do you need?
                </label>
                <select
                    x-model="service"
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#FF6F61] focus:border-transparent transition-all"
                >
                    <option value="">Select service</option>
                    {
                        services.map((svc) => (
                            <option value={svc.slug}>{svc.name}</option>
                        ))
                    }
                </select>
            </div>
        </div>

        <button
            type="submit"
            class="w-full bg-gradient-to-r from-[#FF6F61] to-[#FF8577] text-white font-bold py-4 px-6 rounded-xl hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
        >
            Find Agencies
        </button>
    </form>

    <!-- Corporate Form -->
    <form
        x-show="activeTab === 'corporate'"
        x-cloak
        @submit.prevent="handleCorporateSubmit()"
        class="p-8 space-y-6"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
    >
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Company Name -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">
                    <svg
                        class="w-4 h-4 inline-block mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                        ></path>
                    </svg>
                    Company Name
                </label>
                <input
                    type="text"
                    x-model="companyName"
                    placeholder="Your company name"
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#FF6F61] focus:border-transparent transition-all"
                    required
                />
            </div>

            <!-- Yearly Volume -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">
                    <svg
                        class="w-4 h-4 inline-block mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                        ></path>
                    </svg>
                    Yearly Relocation Volume
                </label>
                <select
                    x-model="yearlyVolume"
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#FF6F61] focus:border-transparent transition-all"
                    required
                >
                    <option value="">Select volume</option>
                    <option value="1-5">1-5 relocations/year</option>
                    <option value="6-20">6-20 relocations/year</option>
                    <option value="21-50">21-50 relocations/year</option>
                    <option value="50+">50+ relocations/year</option>
                </select>
            </div>

            <!-- Primary Destination -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">
                    <svg
                        class="w-4 h-4 inline-block mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                        ></path>
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    Primary Destination
                </label>
                <select
                    x-model="primaryDestination"
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#FF6F61] focus:border-transparent transition-all"
                >
                    <option value="">Select destination</option>
                    {
                        cantons.map((canton) => (
                            <option value={canton.slug}>{canton.name}</option>
                        ))
                    }
                </select>
            </div>
        </div>

        <button
            type="submit"
            class="w-full bg-gradient-to-r from-[#FF6F61] to-[#FF8577] text-white font-bold py-4 px-6 rounded-xl hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
        >
            Get Corporate Solutions
        </button>
    </form>
</div>

<style>
    /* Ensure Alpine.js transitions work smoothly */
    [x-cloak] {
        display: none !important;
    }
</style>
