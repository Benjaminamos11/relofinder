---
// Lists the agency profiles that serve a given region, linking each individual
// /companies/{slug}/ profile. This adds contextual internal links to profiles
// (key indexation signal) and gives region pages real "agencies here" content.
import { supabase } from "../../lib/supabase";

interface Props {
  region: string; // e.g. "Zurich" — matched case-insensitively against regions_served
  aliases?: string[]; // extra region spellings to match (e.g. ["Vaud"] for Lausanne)
  title?: string;
  limit?: number;
}

const { region, aliases = [], title, limit = 24 } = Astro.props;

const { data: relocators } = await supabase
  .from("relocators")
  .select("name, slug, regions_served, rating, tier, logo")
  .not("slug", "is", null);

// Slugs consolidated as duplicates — never link the non-canonical version.
const DUP = new Set([
  "harsch",
  "santa-fe-relocation-services",
  "sgier-partner-2",
]);

const needles = [region, ...aliases].map((r) => r.toLowerCase());
const matchAll = region.toLowerCase() === "switzerland";

const agencies = (relocators || [])
  .filter((r) => r.slug && !DUP.has(r.slug))
  .filter((r) => {
    if (matchAll) return true;
    const served = (r.regions_served || []).map((x: string) =>
      String(x).toLowerCase(),
    );
    return (
      served.some((s: string) => needles.some((n) => s.includes(n))) ||
      r.slug === "lodge-relocation"
    );
  })
  .sort((a, b) => {
    const tierRank = (t: string) =>
      t === "preferred" ? 0 : t === "partner" ? 1 : 2;
    const d = tierRank(a.tier) - tierRank(b.tier);
    return d !== 0 ? d : (b.rating || 0) - (a.rating || 0);
  })
  .slice(0, limit);

const heading = title || `Relocation agencies serving ${region}`;
---

{
  agencies.length > 0 && (
    <section class="py-12 md:py-16 bg-white border-t border-slate-100">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-2">
          {heading}
        </h2>
        <p class="text-slate-500 mb-8">
          Independent profiles with verified reviews, services and pricing — compare and request free quotes.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {agencies.map((a) => (
            <a
              href={`/companies/${a.slug}/`}
              class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-5 py-4 hover:border-[#FF6F61] hover:shadow-sm transition-all"
            >
              <span class="font-semibold text-slate-800 group-hover:text-[#FF6F61]">
                {a.name}
              </span>
              <span class="text-xs text-slate-400 whitespace-nowrap">
                {(a.rating || 0).toFixed(1)} ★
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
