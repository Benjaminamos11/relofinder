---
import Layout from "../../layouts/Layout.astro";
import BreadcrumbSchema from "../common/BreadcrumbSchema.astro";
import HeroSearch from "../home/HeroSearch.astro";
import SEOInsightBox from "../common/SEOInsightBox.astro";
import { ArrowRight, CheckCircle2, MapPin } from "lucide-react";

interface Highlight {
  label: string;
  value: string;
}

interface District {
  name: string;
  profile: string;
  rent: string;
  bestFor: string;
}

interface Faq {
  q: string;
  a: string;
}

interface RelatedLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  regionName: string;
  accentName: string;
  badge: string;
  intro: string;
  heroImage: string;
  heroAlt: string;
  initialDestination: string;
  highlights: Highlight[];
  districts: District[];
  costs: Highlight[];
  faqs: Faq[];
  insightTitle: string;
  insight: string[];
  related: RelatedLink[];
}

const {
  title,
  description,
  canonical,
  regionName,
  accentName,
  badge,
  intro,
  heroImage,
  heroAlt,
  initialDestination,
  highlights,
  districts,
  costs,
  faqs,
  insightTitle,
  insight,
  related,
} = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: { "@type": "Answer", text: faq.a },
  })),
};

const regionSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  name: regionName,
  description,
  url: canonical,
};
---

<Layout title={title} description={description} canonical={canonical} schema={[regionSchema, faqSchema]}>
  <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Regions", url: "/regions/" }, { name: regionName }]} />

  <section class="relative min-h-[760px] pt-28 pb-16 lg:pt-36 lg:pb-24 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt={heroAlt} class="h-full w-full object-cover" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/65 via-slate-950/40 to-slate-950/75"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <span class="inline-flex items-center rounded-full bg-slate-950/75 px-4 py-2 text-xs font-bold uppercase tracking-widest text-white ring-1 ring-white/15">
          {badge}
        </span>
        <h1 class="mt-7 text-5xl font-bold tracking-tight text-white md:text-6xl lg:text-7xl">
          Relocation to <span class="text-[#FF6F61]">{accentName}</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg font-medium leading-relaxed text-white/90 md:text-xl">
          {intro}
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-3xl rounded-2xl border border-white/15 bg-white p-1 shadow-2xl shadow-slate-950/20">
        <HeroSearch initialDestination={initialDestination} />
      </div>

      <div class="mx-auto mt-8 grid max-w-5xl gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {highlights.map((item) => (
          <div class="rounded-xl border border-white/15 bg-white/10 p-4 text-white backdrop-blur-md">
            <div class="text-xs font-bold uppercase tracking-widest text-white/60">{item.label}</div>
            <div class="mt-2 text-lg font-bold">{item.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#FF6F61]">Local Fit</span>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
            Where expats actually settle in {regionName}.
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-600">
            Use this page as the first filter, then compare agencies with local housing, permit, and school access. The best provider is usually the one that knows the neighborhood tradeoffs before the first apartment viewing.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <button
              type="button"
              onclick={`window.openAssessmentModal && window.openAssessmentModal('individual', '${initialDestination}', 'housing')`}
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-slate-900 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-slate-800"
            >
              Get local shortlist
              <ArrowRight className="h-4 w-4" />
            </button>
            <a href="/companies/" class="inline-flex items-center justify-center rounded-lg border border-slate-200 px-6 py-3 text-sm font-bold text-slate-900 transition-colors hover:border-[#FF6F61] hover:text-[#FF6F61]">
              Compare agencies
            </a>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {districts.map((district) => (
            <article class="rounded-xl border border-slate-200 bg-slate-50 p-5">
              <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#FF6F61]">
                <MapPin className="h-4 w-4" />
                {district.bestFor}
              </div>
              <h3 class="mt-3 text-xl font-bold text-slate-900">{district.name}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{district.profile}</p>
              <div class="mt-4 rounded-lg bg-white px-3 py-2 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">
                Typical 3.5 room rent: {district.rent}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#FF6F61]">Budget Snapshot</span>
          <h2 class="mt-3 text-3xl font-bold text-slate-900">Plan the first 90 days with fewer surprises.</h2>
          <p class="mt-4 text-slate-600">
            Local costs vary by municipality, commute pattern, insurance model, and school choice. These ranges are directional planning anchors, not quotes.
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {costs.map((item) => (
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <div class="text-sm font-semibold text-slate-500">{item.label}</div>
              <div class="mt-2 text-2xl font-bold text-slate-900">{item.value}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <SEOInsightBox title={insightTitle}>
        {insight.map((paragraph) => <p>{paragraph}</p>)}
      </SEOInsightBox>

      <div class="mt-14 rounded-2xl border border-slate-200 bg-slate-50 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-slate-900">Common relocation questions</h2>
        <div class="mt-6 space-y-5">
          {faqs.map((faq) => (
            <div class="border-t border-slate-200 pt-5 first:border-t-0 first:pt-0">
              <h3 class="flex gap-2 text-base font-bold text-slate-900">
                <CheckCircle2 className="mt-0.5 h-5 w-5 flex-none text-[#FF6F61]" />
                {faq.q}
              </h3>
              <p class="mt-2 pl-7 text-sm leading-relaxed text-slate-600">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        {related.map((link) => (
          <a href={link.href} class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:border-[#FF6F61] hover:text-[#FF6F61]">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
