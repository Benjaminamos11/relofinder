---
import Layout from "../../layouts/Layout.astro";
import BreadcrumbSchema from "../../components/common/BreadcrumbSchema.astro";
import SEOInternalLinks from "../../components/common/SEOInternalLinks.astro";
import { supabase } from "../../lib/supabase";
import { getCompanyInitials, getCompanyLogo, shouldInvertCompanyLogo } from "../../lib/companyVisuals";
import { BadgeCheck, MapPin, Briefcase, Filter, X, Search, Sparkles, Clock, ShieldCheck, ArrowRight } from "lucide-react";

// Fetch ALL relocators from Supabase
const { data: relocators, error: relocatorsError } = await supabase
    .from("relocators")
    .select("*")
    .order("tier", { ascending: true })
    .order("rating", { ascending: false });

if (relocatorsError) {
    console.error("[CompaniesIndex] Supabase error:", relocatorsError.message);
}

// Fetch total review count for global stats
const { data: googleReviews } = await supabase
    .from("google_reviews")
    .select("id");

const totalReviews = googleReviews?.length || 0;

// Calculate average rating from Supabase data
const avgRating =
    relocators && relocators.length > 0
        ? (
              relocators.reduce((sum, r) => sum + (r.rating || 0), 0) /
              relocators.length
          ).toFixed(1)
        : "4.7";
const totalRelocators = relocators?.length || 0;
const preferredCount = (relocators || []).filter((r) => r.tier === "preferred").length;
const partnerCount = (relocators || []).filter((r) => r.tier === "partner").length;

// Map relocators to the structure expected by the template
const sortedCompanies = (relocators || [])
    .filter((r) => r.slug) // Ensure they have a slug
    .map((r) => ({
        slug: r.slug,
        id: r.slug,
        data: {
            name: r.name,
            description:
                r.seo_summary ||
                "Leading relocation specialist in Switzerland.",
            services: r.services || [],
            regions: r.slug === "lodge-relocation" ? ["All Switzerland"] : r.regions_served || [],
            logo: r.logo,
            tier: r.tier,
            label:
                r.tier === "preferred"
                    ? "Preferred"
                    : r.tier === "partner"
                      ? "Partner"
                      : null,
        },
    }));

// Extract unique values for filters
const allServices = [
    ...new Set((relocators || []).flatMap((r) => r.services || [])),
].sort();
const allRegions = [
    ...new Set((relocators || []).flatMap((r) => r.regions_served || [])),
].sort();

const marketMap = [
    {
        name: "AM Relocation",
        slug: "am-relocation",
        primary: "Zurich boutique relocations",
        fit: "Home search, settling-in, school support, and private Zurich-area moves.",
        compare: "Compare if you want a Zurich specialist rather than a national network.",
    },
    {
        name: "Silver Nest Relocation",
        slug: "silver-nest-relocation",
        primary: "Lake Zurich and German-speaking cantons",
        fit: "Family-owned relocation support with housing, education, immigration, and settling-in.",
        compare: "Compare if you value boutique service around Zurich, Zug, and premium lake communities.",
    },
    {
        name: "Anchor Relocation",
        slug: "anchor-relocation",
        primary: "Zurich, Zug, Schwyz, Central Switzerland",
        fit: "Relocation plus property services for families, executives, and companies.",
        compare: "Compare if property search, letting, or purchase advice may become part of the move.",
    },
    {
        name: "Executive Relocation",
        slug: "executive-relocation",
        primary: "Executive and corporate moves",
        fit: "Senior-professional relocation with orientation, housing, and settling-in support.",
        compare: "Compare if the move is employer-led or time-sensitive.",
    },
    {
        name: "Zurich Relocation",
        slug: "zurich-relocation",
        primary: "Furnished apartments and temporary housing",
        fit: "Short- and long-stay furnished apartment needs in Zurich.",
        compare: "Compare if your first bottleneck is immediate accommodation rather than full-service relocation.",
    },
    {
        name: "Bridging Cultures Relocation",
        slug: "bridging-cultures-relocation",
        primary: "Individual and corporate transition support",
        fit: "Tailored relocation plans for families, couples, singles, and companies.",
        compare: "Compare if cultural integration and high-touch guidance matter as much as housing.",
    },
];

// Page metadata
const title =
    `Relocation Companies Switzerland: Compare ${totalRelocators || 57} Agencies | ReloFinder`;
const description =
    `Compare ${totalRelocators || 57} Swiss relocation companies by city, services, reviews, and fit. Get a free shortlist for Zurich, Geneva, Basel, Zug, Lausanne, and more.`;
const canonical = "https://relofinder.ch/companies/";

const companyFaqs = [
  {
    question: "How does ReloFinder verify relocation agencies?",
    answer: "We verify agencies through Google Reviews analysis, website audits, service portfolio checks, and direct agency partnerships. Preferred and Partner tier agencies undergo additional vetting for quality assurance."
  },
  {
    question: "Is the ReloFinder directory free to use?",
    answer: "Yes, searching and comparing agencies is completely free for individuals and companies. Agencies can upgrade to Partner or Preferred tiers for enhanced visibility."
  },
  {
    question: "What services do Swiss relocation agencies typically offer?",
    answer: "Most agencies offer housing search, immigration and permit support, school search for families, settling-in services, insurance guidance, and moving logistics. Some specialize in corporate relocation or specific regions like Zurich or Geneva."
  },
  {
    question: "How do I choose the right relocation agency for my move?",
    answer: "Consider your specific needs (visa support, housing, schools), preferred region, budget, and language requirements. Use ReloFinder's filters to narrow down agencies, then compare reviews and service offerings side by side."
  },
  {
    question: "Can I compare multiple relocation agencies side by side?",
    answer: "Yes, ReloFinder lets you compare agencies by services offered, regions covered, Google reviews, verification status, and pricing models. Use our AI chat for personalized recommendations."
  }
];

---

<Layout title={title} description={description} canonical={canonical} navbarVariant="solid">
    <BreadcrumbSchema items={[{ name: "Home", url: "/" }, { name: "Directory" }]} />
    <!-- Hero Section -->
    <section
        class="relative pt-10 pb-20 md:pt-14 md:pb-24 bg-slate-50 border-b border-slate-100 overflow-hidden"
    >
        <!-- Subtle Background Grid -->
        <div
            class="absolute inset-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-40"
        >
        </div>

        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-4xl mx-auto text-center">
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-200/50 border border-slate-200 text-slate-600 text-[11px] font-bold uppercase tracking-widest mb-6 animate-fade-in"
                >
                    <span
                        class="w-2 h-2 rounded-full bg-[#FF6F61] animate-pulse"
                    ></span>
                    Directory 2026
                </div>
                <h1
                    class="text-4xl md:text-6xl font-bold tracking-tight text-slate-900 mb-6 leading-tight"
                >
                    Relocation Companies
                    <span class="text-[#FF6F61]">in Switzerland</span>
                </h1>
                <p
                    class="text-xl text-slate-500 font-normal leading-relaxed max-w-2xl mx-auto"
                >
                    Compare verified Swiss relocation providers by region,
                    service scope, review signal, and fit for your move.
                </p>
                <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-3xl mx-auto text-left">
                    <div class="bg-white/90 border border-slate-200 rounded-xl p-4 shadow-sm">
                        <div class="text-2xl font-bold text-slate-950">{totalRelocators}+</div>
                        <div class="text-xs font-semibold uppercase tracking-widest text-slate-500">Listed providers</div>
                    </div>
                    <div class="bg-white/90 border border-slate-200 rounded-xl p-4 shadow-sm">
                        <div class="text-2xl font-bold text-slate-950">{preferredCount + partnerCount}</div>
                        <div class="text-xs font-semibold uppercase tracking-widest text-slate-500">Enhanced profiles</div>
                    </div>
                    <div class="bg-white/90 border border-slate-200 rounded-xl p-4 shadow-sm">
                        <div class="text-2xl font-bold text-slate-950">{totalReviews || "Live"}</div>
                        <div class="text-xs font-semibold uppercase tracking-widest text-slate-500">Review signals</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-slate-950 text-white">
        <div class="container mx-auto px-4 py-8">
            <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-6 items-center">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#FFB3AA] mb-3">Not sure who fits?</p>
                    <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">Get a human-reviewed shortlist before you contact agencies.</h2>
                    <p class="text-sm md:text-base text-slate-300 max-w-3xl">
                        Tell us your canton, services, timeline, and budget. We filter for providers with the right coverage and send a focused shortlist instead of making you message ten firms.
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-3 lg:justify-end">
                    <button
                        onclick="window.openAssessmentModal && window.openAssessmentModal('full')"
                        class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#FF6F61] px-5 py-4 text-sm font-bold uppercase tracking-widest text-white hover:bg-[#ff5a4d] transition-colors"
                    >
                        <Sparkles className="h-4 w-4" /> Get free shortlist
                    </button>
                    <a
                        href="#directory-results"
                        class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 px-5 py-4 text-sm font-bold uppercase tracking-widest text-white hover:bg-white/10 transition-colors"
                    >
                        Browse all
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-white border-b border-slate-200">
        <div class="container mx-auto px-4 py-14 md:py-18">
            <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#FF6F61] mb-4">
                        Swiss relocation market map
                    </p>
                    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-950">
                        Searchers compare named agencies first. We make the shortlist easier to trust.
                    </h2>
                    <p class="mt-5 text-slate-600 leading-relaxed">
                        The Zurich and Switzerland search results are full of individual agency homepages. This view gives you the same starting point, plus profile context, fit signals, and a faster path to a human-reviewed shortlist.
                    </p>
                    <button
                        type="button"
                        onclick="window.openAssessmentModal && window.openAssessmentModal('full')"
                        class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl bg-slate-950 px-5 py-4 text-sm font-bold text-white transition-colors hover:bg-slate-800"
                    >
                        Get free shortlist
                        <Sparkles className="h-4 w-4 text-[#FF6F61]" />
                    </button>
                </div>

                <div class="overflow-hidden rounded-2xl border border-slate-200">
                    <div class="hidden md:grid grid-cols-[1fr_1fr_1fr_auto] gap-4 bg-slate-50 px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                        <span>Agency</span>
                        <span>Primary signal</span>
                        <span>Best-fit use case</span>
                        <span>Profile</span>
                    </div>
                    <div class="divide-y divide-slate-200">
                        {marketMap.map((agency) => (
                            <article class="grid gap-3 p-5 md:grid-cols-[1fr_1fr_1fr_auto] md:items-center md:gap-4">
                                <div>
                                    <h3 class="font-bold text-slate-950">{agency.name}</h3>
                                    <p class="mt-1 text-xs font-semibold text-slate-500 md:hidden">{agency.primary}</p>
                                </div>
                                <p class="hidden text-sm text-slate-600 md:block">{agency.primary}</p>
                                <p class="text-sm leading-relaxed text-slate-600">
                                    {agency.fit}
                                    <span class="mt-1 block text-xs font-semibold text-slate-500">{agency.compare}</span>
                                </p>
                                <a
                                    href={`/companies/${agency.slug}/`}
                                    class="inline-flex items-center justify-center rounded-lg border border-slate-200 px-4 py-2 text-xs font-bold uppercase tracking-widest text-slate-700 transition-colors hover:border-[#FF6F61] hover:text-[#FF6F61]"
                                >
                                    View
                                </a>
                            </article>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <SEOInternalLinks
        variant="directory"
        title="Fast paths into the provider directory"
    />

    <!-- Filter & Grid Section -->
    <section id="directory-results" class="py-12 md:py-20 bg-white min-h-screen scroll-mt-24">
        <div class="container mx-auto px-4">
            <!-- Filters Layout (Sticky Desktop, Stacked Mobile) -->
            <div
                class="lg:grid lg:grid-cols-[280px_1fr] lg:gap-12 lg:items-start relative"
            >
                <!-- Sidebar Filters -->
                <aside
                    class="hidden lg:block sticky top-24 space-y-8 animate-fade-in-up"
                >
                    <div>
                        <h3
                            class="text-xs font-bold text-slate-900 uppercase tracking-widest mb-4 flex items-center gap-2"
                        >
                            <Filter className="w-4 h-4" /> Filters
                        </h3>

                        <!-- Search -->
                        <div class="relative mb-6">
                            <input
                                type="text"
                                id="searchInput"
                                placeholder="Search companies..."
                                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-slate-400 focus:bg-white transition-all placeholder:text-slate-400"
                            />
                        </div>

                        <!-- Region Filter -->
                        <div class="space-y-3 mb-6">
                            <label
                                class="text-sm font-semibold text-slate-900 block"
                                >Region</label
                            >
                            <div class="relative">
                                <select
                                    id="regionFilter"
                                    class="w-full appearance-none bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-slate-400 cursor-pointer"
                                >
                                    <option value="">All Switzerland</option>
                                    {
                                        allRegions.map((r) => (
                                            <option value={r}>
                                                {r.charAt(0).toUpperCase() +
                                                    r.slice(1)}
                                            </option>
                                        ))
                                    }
                                </select>
                                <div
                                    class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"
                                >
                                    <svg
                                        class="w-4 h-4 text-slate-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Service Filter -->
                        <div class="space-y-3 mb-6">
                            <label
                                class="text-sm font-semibold text-slate-900 block"
                                >Service Focus</label
                            >
                            <div class="relative">
                                <select
                                    id="serviceFilter"
                                    class="w-full appearance-none bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-slate-400 cursor-pointer"
                                >
                                    <option value="">All Services</option>
                                    {
                                        allServices.map((s) => (
                                            <option value={s}>
                                                {s
                                                    .replace(/-/g, " ")
                                                    .replace(/\b\w/g, (l) =>
                                                        l.toUpperCase(),
                                                    )}
                                            </option>
                                        ))
                                    }
                                </select>
                                <div
                                    class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"
                                >
                                    <svg
                                        class="w-4 h-4 text-slate-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Tier Filter -->
                        <div class="space-y-3">
                            <label
                                class="text-sm font-semibold text-slate-900 block"
                                >Verification</label
                            >
                            <div class="flex gap-2">
                                <button
                                    id="verifiedBtn"
                                    class="flex-1 px-4 py-2 border border-slate-200 text-xs font-bold uppercase tracking-wider text-slate-500 rounded-xl hover:border-slate-900 hover:text-slate-900 transition-colors"
                                    data-value="verified"
                                >
                                    Verified
                                </button>
                                <button
                                    id="resetBtn"
                                    class="px-4 py-2 border border-slate-200 text-slate-400 hover:text-[#FF6F61] hover:border-[#FF6F61] rounded-xl transition-colors"
                                    aria-label="Reset"
                                >
                                    <X className="w-4 h-4" />
                                </button>
                            </div>
                        </div>

                        <div class="pt-6 border-t border-slate-100 mt-6">
                            <p class="text-xs text-slate-400">
                                Showing <span
                                    id="countDisplay"
                                    class="font-bold text-slate-900"
                                    >{sortedCompanies.length}</span
                                > agencies
                            </p>
                        </div>

                        <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4">Fast routes</p>
                            <div class="space-y-2">
                                <button type="button" class="quick-filter w-full text-left rounded-xl bg-white border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800 hover:border-[#FF6F61] transition-colors" data-service="housing">Housing search</button>
                                <button type="button" class="quick-filter w-full text-left rounded-xl bg-white border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800 hover:border-[#FF6F61] transition-colors" data-service="immigration">Permit support</button>
                                <button type="button" class="quick-filter w-full text-left rounded-xl bg-white border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800 hover:border-[#FF6F61] transition-colors" data-service="school">School search</button>
                            </div>
                        </div>
                    </div>
                </aside>

                <!-- Main Grid -->
                <main>
                    <!-- Mobile Mobile Filter Toggle (Visible only on lg and below) -->
                    <div class="lg:hidden mb-8">
                        <details
                            class="group bg-slate-50 border border-slate-200"
                        >
                            <summary
                                class="flex items-center justify-between p-4 cursor-pointer font-bold text-slate-900 uppercase tracking-widest text-xs list-none"
                            >
                                <span>Filter Directory</span>
                                <Filter className="w-4 h-4" />
                            </summary>
                            <div
                                class="p-4 border-t border-slate-200 space-y-4"
                            >
                                <!-- Mobile Filters Content (Simplified copy of sidebar) -->
                                <input
                                    type="text"
                                    id="mobileSearch"
                                    placeholder="Search..."
                                    class="w-full bg-white border border-slate-200 p-3 text-sm"
                                />
                                <select
                                    id="mobileRegion"
                                    class="w-full bg-white border border-slate-200 p-3 text-sm"
                                >
                                    <option value="">All Regions</option>
                                    {
                                        allRegions.map((r) => (
                                            <option value={r}>{r}</option>
                                        ))
                                    }
                                </select>
                                <select
                                    id="mobileService"
                                    class="w-full bg-white border border-slate-200 p-3 text-sm"
                                >
                                    <option value="">All Services</option>
                                    {
                                        allServices.map((s) => (
                                            <option value={s}>{s}</option>
                                        ))
                                    }
                                </select>
                                <button
                                    type="button"
                                    onclick="window.openAssessmentModal && window.openAssessmentModal('full')"
                                    class="w-full bg-slate-950 text-white p-3 text-xs font-bold uppercase tracking-widest"
                                >
                                    Get free shortlist
                                </button>
                            </div>
                        </details>
                    </div>

                    <div class="mb-8 rounded-2xl border border-slate-200 bg-slate-50 p-5 md:p-6">
                        <div class="grid md:grid-cols-[1fr_auto] gap-5 items-center">
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Directory mode</p>
                                <h2 class="text-2xl font-bold text-slate-950 tracking-tight">Filter, inspect, then request a shortlist.</h2>
                                <p class="text-sm text-slate-600 mt-2 max-w-2xl">
                                    The best choice depends on your canton, family situation, permit path, and housing urgency. Use filters to narrow the field, or let ReloFinder review your requirements.
                                </p>
                            </div>
                            <div class="grid grid-cols-3 gap-2 text-center">
                                <div class="rounded-xl bg-white border border-slate-200 p-3">
                                    <Search className="h-4 w-4 mx-auto text-[#FF6F61] mb-2" />
                                    <span class="block text-[10px] font-bold uppercase tracking-wider text-slate-500">Filter</span>
                                </div>
                                <div class="rounded-xl bg-white border border-slate-200 p-3">
                                    <ShieldCheck className="h-4 w-4 mx-auto text-[#FF6F61] mb-2" />
                                    <span class="block text-[10px] font-bold uppercase tracking-wider text-slate-500">Verify</span>
                                </div>
                                <div class="rounded-xl bg-white border border-slate-200 p-3">
                                    <Clock className="h-4 w-4 mx-auto text-[#FF6F61] mb-2" />
                                    <span class="block text-[10px] font-bold uppercase tracking-wider text-slate-500">Shortlist</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div
                        id="companyGrid"
                        class="grid md:grid-cols-2 lg:grid-cols-3 gap-6"
                    >
                        {
                            sortedCompanies.map((company) => {
                                const tier = company.data.tier || "standard";
                                const displayLogo = getCompanyLogo(company.slug, company.data.logo);
                                const initials = getCompanyInitials(company.data.name);

                                return (
                                    <a
                                        href={`/companies/${company.slug}/`}
                                        class="group relative bg-white border border-slate-200 rounded-2xl hover:border-[#FF6F61] hover:shadow-xl hover:shadow-slate-200/70 transition-all duration-300 flex flex-col h-full min-h-[320px] company-card focus:outline-none focus:ring-2 focus:ring-[#FF6F61]/40"
                                        data-name={company.data.name.toLowerCase()}
                                        data-region={company.data.regions
                                            .join(" ")
                                            .toLowerCase()}
                                        data-service={company.data.services
                                            .join(" ")
                                            .toLowerCase()}
                                        data-verified={
                                            tier === "preferred" ||
                                            tier === "partner"
                                                ? "true"
                                                : "false"
                                        }
                                    >
                                        {/* Card Content Container */}
                                        <div class="p-6 md:p-7 flex flex-col h-full relative z-10">
                                            {/* Top Badge: Centered & Overlapping */}
                                            {tier === "preferred" && (
                                                <div class="absolute left-1/2 -top-3 -translate-x-1/2 bg-black text-white px-3 py-1 text-[10px] font-bold uppercase tracking-widest flex items-center gap-1 rounded-full shadow-md z-20">
                                                    <BadgeCheck className="w-3 h-3 text-[#FF6F61]" />
                                                    Preferred
                                                </div>
                                            )}

                                            {/* Header: Logo or Name */}
                                            <div class="flex justify-center items-center mb-5 h-16">
                                                <div data-logo-shell class="relative flex h-16 w-40 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 px-4">
                                                    <div class="absolute inset-0 flex items-center justify-center">
                                                        <span class="text-lg font-black tracking-tight text-slate-300" data-logo-initials>
                                                            {initials}
                                                        </span>
                                                    </div>
                                                    {displayLogo && (
                                                    <img
                                                        src={displayLogo}
                                                        alt={company.data.name}
                                                        width={200}
                                                        height={80}
                                                        loading="lazy"
                                                        decoding="async"
                                                        onerror="this.classList.add('hidden'); this.closest('[data-logo-shell]')?.classList.add('logo-fallback')"
                                                        data-logo-frame
                                                        class={`relative z-10 max-h-10 w-auto object-contain grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 ${shouldInvertCompanyLogo(company.data.name) ? "invert" : ""}`}
                                                    />
                                                    )}
                                                </div>
                                            </div>

                                            {/* Body: Name & Desc - Only show name if no logo was shown above, or always show for clarity? Let's hide name if logo exists to be super clean, or keep it small. Strategy: Always show name for SEO/Clarity but smaller. */}

                                            <div class="mb-6 flex-grow">
                                                <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#FF6F61] transition-colors line-clamp-2">
                                                    {company.data.name}
                                                </h3>
                                                <div class="flex flex-wrap items-center gap-2 mt-2 mb-3">
                                                    {company.data.label && (
                                                        <span class="inline-block px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 text-[10px] font-bold uppercase tracking-wide border border-slate-200">
                                                            {company.data.label}
                                                        </span>
                                                    )}
                                                    <span class="inline-block px-2 py-0.5 rounded-full bg-[#FFF1EF] text-[#B8463C] text-[10px] font-bold uppercase tracking-wide border border-[#FFD7D1]">
                                                        {tier === "preferred" ? "Priority response" : tier === "partner" ? "Profile enhanced" : "Listed profile"}
                                                    </span>
                                                </div>
                                                <p class="text-sm text-slate-500 leading-relaxed line-clamp-3">
                                                    {company.data.description}
                                                </p>
                                            </div>

                                            {/* Footer: Meta Data */}
                                            <div class="pt-5 border-t border-slate-100 mt-auto space-y-3">
                                                <div class="flex items-start gap-3">
                                                    <Briefcase className="w-4 h-4 text-[#FF6F61] mt-0.5 shrink-0" />
                                                    <span class="text-xs text-slate-500 font-medium leading-relaxed">
                                                        {company.data.services
                                                            .slice(0, 3)
                                                            .join(", ")}
                                                        {company.data.services
                                                            .length > 3 &&
                                                            "..."}
                                                    </span>
                                                </div>
                                                <div class="flex items-center gap-3">
                                                    <MapPin className="w-4 h-4 text-[#FF6F61] shrink-0" />
                                                    <span class="text-xs text-slate-500 font-medium truncate">
                                                        {company.data.regions
                                                            .slice(0, 3)
                                                            .join(", ")}
                                                    </span>
                                                </div>
                                                <div class="flex items-center justify-between gap-3 pt-3">
                                                    <span class="min-w-0 text-[10px] font-bold uppercase tracking-widest text-slate-400">Profile, reviews, fit signals</span>
                                                    <span class="inline-flex shrink-0 items-center gap-1 rounded-lg bg-[#FFF1EF] px-3 py-2 text-xs font-bold text-[#B8463C]">
                                                        Open <ArrowRight className="h-3 w-3" />
                                                    </span>
                                                </div>
                                            </div>

                                            {/* Hover Arrow (Architectural) */}
                                            <div class="absolute bottom-8 right-8 opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-4 group-hover:translate-x-0">
                                                <svg
                                                    class="w-5 h-5 text-[#FF6F61]"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                                    />
                                                </svg>
                                            </div>

                                            {/* Removed Compare Checkbox to enforce Concierge Flow */}
                                        </div>

                                        {/* Subtle background wash on hover */}
                                        <div class="absolute inset-0 bg-slate-50 opacity-0 group-hover:opacity-50 transition-opacity duration-300 pointer-events-none -z-0" />
                                    </a>
                                );
                            })
                        }
                    </div>

                    <!-- No Results State -->
                    <div id="noResults" class="hidden py-24 text-center">
                        <div
                            class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 mb-6"
                        >
                            <Filter className="w-6 h-6 text-slate-400" />
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">
                            No partners found.
                        </h3>
                        <p class="text-slate-500">
                            Try adjusting your filters, or request a free shortlist and we will review the market for you.
                        </p>
                        <button
                            type="button"
                            onclick="window.openAssessmentModal && window.openAssessmentModal('full')"
                            class="mt-6 inline-flex items-center justify-center gap-2 rounded-xl bg-[#FF6F61] px-5 py-4 text-sm font-bold text-white hover:bg-[#ff5a4d] transition-colors"
                        >
                            Get free shortlist
                        </button>
                    </div>
                </main>
            </div>
        </div>
    </section>

    <!-- Client-Side Filtering -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const searchInput = document.getElementById("searchInput");
            const regionFilter = document.getElementById("regionFilter");
            const serviceFilter = document.getElementById("serviceFilter");
            const verifiedBtn = document.getElementById("verifiedBtn");
            const resetBtn = document.getElementById("resetBtn");
            const quickFilters = document.querySelectorAll(".quick-filter");
            const cards = document.querySelectorAll(".company-card");
            const countDisplay = document.getElementById("countDisplay");
            const noResults = document.getElementById("noResults");
            const grid = document.getElementById("companyGrid");
            const params = new URLSearchParams(window.location.search);

            // Mobile inputs sync (basic implementation)
            const mobileSearch = document.getElementById("mobileSearch");
            const mobileRegion = document.getElementById("mobileRegion");
            const mobileService = document.getElementById("mobileService");

            if (mobileSearch)
                mobileSearch.addEventListener("input", (e) => {
                    if (searchInput) searchInput.value = e.target.value;
                    filter();
                });
            if (mobileRegion)
                mobileRegion.addEventListener("change", (e) => {
                    if (regionFilter) regionFilter.value = e.target.value;
                    filter();
                });
            if (mobileService)
                mobileService.addEventListener("change", (e) => {
                    if (serviceFilter) serviceFilter.value = e.target.value;
                    filter();
                });

            let verifiedOnly = false;

            function cleanParam(value) {
                return (value || "")
                    .toLowerCase()
                    .replace(/\/+$/, "")
                    .replace(/&/g, " ")
                    .replace(/[^a-z0-9]+/g, " ")
                    .trim();
            }

            function normalizeServiceParam(value) {
                const cleaned = cleanParam(value);
                const aliases = {
                    housing: "home search",
                    "home search": "home search",
                    apartment: "apartment search",
                    immigration: "visa immigration",
                    "immigration services": "visa immigration",
                    visa: "visa immigration",
                    education: "school search",
                    school: "school search",
                    "school search": "school search",
                    moving: "moving managment",
                    "moving logistics": "moving managment",
                    "move management": "moving managment",
                    insurance: "insurance guidance",
                    finance: "tax legal",
                    advisory: "legal advice",
                    "settling in": "settling in",
                    departure: "departure support",
                };
                return aliases[cleaned] || cleaned;
            }

            function setSelectFromParam(select, value, type = "default") {
                if (!select || !value) return;
                const cleaned = type === "service" ? normalizeServiceParam(value) : cleanParam(value);
                const option = Array.from(select.options).find((item) => {
                    const optionValue = type === "service" ? normalizeServiceParam(item.value) : cleanParam(item.value);
                    const optionText = type === "service" ? normalizeServiceParam(item.textContent || "") : cleanParam(item.textContent || "");
                    return optionValue === cleaned || optionValue.includes(cleaned) || optionText.includes(cleaned);
                });
                if (option) select.value = option.value;
            }

            function applyInitialUrlFilters() {
                const search = cleanParam(params.get("search") || params.get("q"));
                const region = cleanParam(params.get("region"));
                const service = cleanParam(params.get("service"));
                const tier = cleanParam(params.get("tier"));

                if (search && searchInput) searchInput.value = search;
                setSelectFromParam(regionFilter, region);
                setSelectFromParam(serviceFilter, service, "service");

                if (tier === "preferred" || tier === "partner" || tier === "verified") {
                    verifiedOnly = true;
                    verifiedBtn?.classList.add("bg-slate-900", "text-white", "border-slate-900");
                }

                if (mobileSearch && search) mobileSearch.value = search;
                setSelectFromParam(mobileRegion, region);
                setSelectFromParam(mobileService, service, "service");
            }

            function filter() {
                const term = searchInput ? searchInput.value.toLowerCase() : "";
                const region = regionFilter
                    ? regionFilter.value.toLowerCase()
                    : "";
                const service = serviceFilter
                    ? serviceFilter.value.toLowerCase()
                    : "";

                let visible = 0;

                cards.forEach((card) => {
                    const name = card.getAttribute("data-name");
                    const regions = card.getAttribute("data-region");
                    const services = card.getAttribute("data-service");
                    const isVerified =
                        card.getAttribute("data-verified") === "true";

                    const matchesSearch = name.includes(term);
                    const matchesRegion =
                        region === "" || regions.includes(region);
                    const matchesService =
                        service === "" || services.includes(service);
                    const matchesVerified = !verifiedOnly || isVerified;

                    if (
                        matchesSearch &&
                        matchesRegion &&
                        matchesService &&
                        matchesVerified
                    ) {
                        card.style.display = "flex"; // Restore flex for card layout
                        visible++;
                    } else {
                        card.style.display = "none";
                    }
                });

                if (countDisplay) countDisplay.textContent = visible;

                if (visible === 0) {
                    noResults.classList.remove("hidden");
                    grid.classList.add("hidden");
                } else {
                    noResults.classList.add("hidden");
                    grid.classList.remove("hidden");
                }
            }

            // Event Listeners
            if (searchInput) searchInput.addEventListener("input", filter);
            if (regionFilter) regionFilter.addEventListener("change", filter);
            if (serviceFilter) serviceFilter.addEventListener("change", filter);
            quickFilters.forEach((button) => {
                button.addEventListener("click", () => {
                    const serviceHint = button.getAttribute("data-service") || "";
                    if (serviceFilter) {
                        const option = Array.from(serviceFilter.options).find((item) =>
                            item.value.toLowerCase().includes(serviceHint),
                        );
                        serviceFilter.value = option ? option.value : "";
                    }
                    filter();
                });
            });

            if (verifiedBtn)
                verifiedBtn.addEventListener("click", () => {
                    verifiedOnly = !verifiedOnly;
                    verifiedBtn.classList.toggle("bg-slate-900");
                    verifiedBtn.classList.toggle("text-white");
                    verifiedBtn.classList.toggle("border-slate-900");
                    filter();
                });

            if (resetBtn)
                resetBtn.addEventListener("click", () => {
                    if (searchInput) searchInput.value = "";
                    if (regionFilter) regionFilter.value = "";
                    if (serviceFilter) serviceFilter.value = "";
                    verifiedOnly = false;
                    verifiedBtn.classList.remove(
                        "bg-slate-900",
                        "text-white",
                        "border-slate-900",
                    );
                    filter();
                });

            applyInitialUrlFilters();
            filter();
        });
    </script>

    <!-- FAQ Section -->
    <section class="py-16 bg-gray-50">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-2xl font-bold text-slate-800 mb-8">Frequently Asked Questions</h2>
            <div class="space-y-4">
                {companyFaqs.map((faq) => (
                    <details class="bg-white rounded-xl border border-slate-200 overflow-hidden group">
                        <summary class="px-6 py-4 cursor-pointer font-semibold text-slate-800 hover:bg-slate-50 transition-colors flex justify-between items-center">
                            {faq.question}
                            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <p class="px-6 pb-4 text-slate-600 leading-relaxed">{faq.answer}</p>
                    </details>
                ))}
            </div>
        </div>
    </section>
</Layout>
