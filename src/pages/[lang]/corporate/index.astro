---
import CorporateLanding from '../../../components/corporate/CorporateLanding.astro';

export const prerender = true;

export function getStaticPaths() {
  // /en/corporate/ removed — its canonical is /corporate/ so it was a
  // non-canonical duplicate flagged by Ahrefs. The English version
  // is served only from /corporate/.
  return [
    { params: { lang: 'de' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
---

<CorporateLanding lang={lang as 'en' | 'de' | 'fr'} />
