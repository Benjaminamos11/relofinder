---
import Layout from "../layouts/Layout.astro";
import { Mail } from "lucide-react";

const title = "Terms of Service | ReloFinder.ch";
const description = "Terms and conditions for using the ReloFinder platform.";
const canonical = "https://relofinder.ch/terms/";
const lastUpdated = "February 28, 2026";

const combinedSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://relofinder.ch",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Terms of Service",
          item: "https://relofinder.ch/terms",
        },
      ],
    },
    {
      "@type": "WebPage",
      name: title,
      description: description,
      url: canonical,
      datePublished: "2026-02-28",
      dateModified: "2026-02-28",
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  schema={combinedSchema}
>
  <main class="max-w-4xl mx-auto px-4 py-16 prose prose-slate">
    <span
      class="inline-block py-1 px-3 rounded-full bg-gray-100 text-gray-600 text-xs font-bold uppercase tracking-widest mb-6 not-prose"
    >
      Legal
    </span>
    <h1
      class="text-4xl md:text-5xl font-serif font-bold text-gray-900 mb-4 leading-tight"
    >
      Terms of Service
    </h1>
    <div
      class="flex items-center gap-4 text-gray-500 text-sm border-b border-gray-100 pb-8 mb-8 not-prose"
    >
      <span>Last Updated: {lastUpdated}</span>
    </div>

    <p class="lead text-xl text-gray-500 mb-12 not-prose">
      By accessing and using ReloFinder.ch ("the Platform"), you accept and
      agree to be bound by these Terms of Service. If you do not agree to these
      terms, please do not use our services.
    </p>

    <h2>1. Operator & Legal Entity</h2>
    <p>
      The Platform is owned and operated by <strong
        >Expat Digital Group LLC</strong
      > (1209 MOUNTAIN ROAD PL NE STE N, ALBUQUERQUE, BERNALILLO COUNTY, NM 87110
      USA).
    </p>

    <h2>2. Description of Services</h2>
    <p>
      ReloFinder.ch acts as an intermediary platform connecting individuals and
      corporations ("Users") with relocation agencies, moving companies, and
      other service providers ("Partners"). We facilitate the quotation and
      comparison process but do not directly provide relocation services.
    </p>

    <h2>3. User Responsibilities</h2>
    <p>By using the Platform, you agree to:</p>
    <ul>
      <li>Provide accurate, current, and complete information.</li>
      <li>Maintain the confidentiality of any account credentials.</li>
      <li>Use the services only for lawful purposes.</li>
      <li>Not interfere with the proper working of the Platform.</li>
    </ul>

    <h2>4. Disclaimer of Warranties</h2>
    <p>
      The Platform and services are provided "as is" and "as available". While
      we vet our Partners carefully, we do not guarantee the quality, safety, or
      legality of the services provided by third-party Partners. Any agreement
      entered into is strictly between the User and the Partner.
    </p>

    <h2>5. Limitation of Liability</h2>
    <p>
      To the fullest extent permitted by law, Expat Digital Group LLC shall not
      be liable for any indirect, incidental, special, consequential, or
      punitive damages, or any loss of profits or revenues, whether incurred
      directly or indirectly, resulting from:
    </p>
    <ul>
      <li>Your use or inability to use the Platform.</li>
      <li>Any conduct or content of any third party.</li>
      <li>Any services provided by Partners connected through the Platform.</li>
    </ul>

    <h2>6. Content and Intellectual Property</h2>
    <p>
      All content on the Platform (text, graphics, logos, software) is the
      property of Expat Digital Group LLC or its licensors and is protected by
      copyright and intellectual property laws. You may not reproduce,
      distribute, or create derivative works without our express written
      permission.
    </p>

    <h2>7. Modifications to Terms</h2>
    <p>
      We reserve the right to modify these Terms at any time. We will notify
      users of significant changes by updating the "Last Updated" date at the
      top of this page. Your continued use of the Platform constitutes
      acceptance of the modified Terms.
    </p>

    <h2>8. Governing Law</h2>
    <p>
      These Terms shall be governed by the laws applicable to Expat Digital
      Group LLC, without regard to its conflict of law provisions.
    </p>

    <h2>9. Contact Us</h2>
    <p>If you have any questions about these Terms, please contact us at:</p>
    <div class="not-prose mt-6">
      <a
        href="mailto:hello@relofinder.ch"
        class="flex items-center text-lg font-bold text-gray-900 hover:text-[#FF6F61] transition-colors"
      >
        <Mail className="w-5 h-5 mr-3" />
        hello@relofinder.ch
      </a>
    </div>
  </main>
</Layout>
